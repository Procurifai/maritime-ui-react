{
  "name": "@procurifai/maritime-ui",
  "version": "0.0.0",
  "description": "Pure React + Tailwind components for maritime, bridge, and operations UIs. Clean-room rewrite of the OpenBridge design language.",
  "keywords": [
    "react",
    "tailwind",
    "maritime",
    "openbridge",
    "iec-62288",
    "design-system",
    "ui-components"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Procurifai/maritime-ui-react.git",
    "directory": "packages/maritime-ui"
  },
  "homepage": "https://maritime.ui",
  "bugs": "https://github.com/Procurifai/maritime-ui-react/issues",
  "author": "Procurifai contributors",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./button": {
      "import": {
        "types": "./dist/button/index.d.ts",
        "default": "./dist/button/index.js"
      },
      "require": {
        "types": "./dist/button/index.d.cts",
        "default": "./dist/button/index.cjs"
      }
    },
    "./card": {
      "import": {
        "types": "./dist/card/index.d.ts",
        "default": "./dist/card/index.js"
      },
      "require": {
        "types": "./dist/card/index.d.cts",
        "default": "./dist/card/index.cjs"
      }
    },
    "./badge": {
      "import": {
        "types": "./dist/badge/index.d.ts",
        "default": "./dist/badge/index.js"
      },
      "require": {
        "types": "./dist/badge/index.d.cts",
        "default": "./dist/badge/index.cjs"
      }
    },
    "./status-indicator": {
      "import": {
        "types": "./dist/status-indicator/index.d.ts",
        "default": "./dist/status-indicator/index.js"
      },
      "require": {
        "types": "./dist/status-indicator/index.d.cts",
        "default": "./dist/status-indicator/index.cjs"
      }
    },
    "./theme": {
      "import": {
        "types": "./dist/theme/index.d.ts",
        "default": "./dist/theme/index.js"
      },
      "require": {
        "types": "./dist/theme/index.d.cts",
        "default": "./dist/theme/index.cjs"
      }
    },
    "./theme/tokens.css": "./dist/theme/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
