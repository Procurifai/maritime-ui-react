{
  "name": "maritime-ui-react",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for @procurifai/maritime-ui + the maritime.ui Astro landing.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Procurifai/maritime-ui-react.git"
  },
  "workspaces": [
    "packages/*",
    "landing"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,mdx,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,mdx,yml,yaml,css}\"",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "manifest": "node scripts/build-component-manifest.mjs",
    "manifest:strict": "node scripts/build-component-manifest.mjs --strict",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@storybook/addon-a11y": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-themes": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@types/node": "^20.16.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^0.11.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.7",
    "tailwindcss": "^4.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "packageManager": "npm@10.8.2"
}
